@startuml
title UC 4.3 - E-Rezept durch Abgebenden löschen

actor "Mitarbeiter Apotheke" as MA
participant "AVS" as AVS
participant "TI-Flow-Fachdienst" as FD

MA -> AVS: E-Rezept löschen()
activate AVS

AVS -> FD: POST /Task/{id}/$abort (Secret)
activate FD
FD -> FD: Status auf "cancelled" setzen()
FD -> FD: Daten löschen()
FD -> FD : Datenzugriff protokollieren()
FD --> AVS: Status
deactivate FD

AVS -> AVS: Token und Secret löschen()
AVS --> MA: Status
deactivate AVS

@enduml
