@startuml
title UC 4.4 - Quittung abrufen

actor "Mitarbeiter Apotheke" as MA
participant "AVS" as AVS
participant "TI-Flow-Fachdienst" as FD

MA -> AVS: Abgabe bestätigen()
activate AVS

AVS -> FD: POST /Task/{id}/$close (Secret, Dispensierinformation)
activate FD
FD -> FD: Secret prüfen()
FD -> FD: Status Task prüfen()
FD -> FD : MedicationDispense speichern()
FD -> FD : Referenz zur MedicationDispense im Task speichern()
FD -> FD: Status auf "completed" setzen()
FD -> FD: Quittung erstellen und signieren()
FD -> FD: Datenzugriff protokollieren()
FD --> AVS: Quittung, Status
deactivate FD

AVS --> MA: Status
deactivate AVS

@enduml
