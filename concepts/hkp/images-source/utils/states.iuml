!procedure $state_correction_requested($alias, $requestor, $owner)
state "<<Korrekturanfrage>>\n CorrectionFlowTask" as $alias #Coral
$alias:status = <b>requested</b>
$alias:businessStatus = <b>correction-requested</b>
$alias:requestor = <b>$requestor</b>
$alias:owner = <b>$owner</b>
$alias:partOf = OrderTask
!endprocedure


!procedure $state_correction_cancelled($alias, $requestor, $owner)
state "<<Korrekturanfrage storniert>>\n CorrectionFlowTask" as $alias #Coral
$alias:status = <b>cancelled</b>
$alias:businessStatus = <b>correction-cancelled</b>
$alias:requestor = <b>$requestor</b>
$alias:owner = <b>$owner</b>
$alias:partOf = OrderTask
!endprocedure


!procedure $state_correction_rejected($alias, $requestor, $owner)
state "<<Korrektur abgelehnt>>\n CorrectionFlowTask" as $alias #Coral
$alias:status = <b>rejected</b>
$alias:businessStatus = <b>correction-rejected</b>
$alias:requestor = <b>$requestor</b>
$alias:owner = <b>$owner</b>
$alias:partOf = OrderTask
!endprocedure


!procedure $state_correction_in_progress($alias, $requestor, $owner)
state "<<Korrektur in Bearbeitung>>\n CorrectionFlowTask" as $alias #Coral
$alias:status = <b>in-progress</b>
$alias:businessStatus = <b>correction-in-progress</b>
$alias:requestor = <b>$requestor</b>
$alias:owner = <b>$owner</b>
$alias:partOf = OrderTask
!endprocedure


!procedure $state_correction_completed($alias, $requestor, $owner)
state "<<Korrektur abgeschlossen>>\n CorrectionFlowTask" as $alias #Coral
$alias:status = <b>completed</b>
$alias:businessStatus = <b>correction-completed</b>
$alias:requestor = <b>$requestor</b>
$alias:owner = <b>$owner</b>
$alias:partOf = OrderTask
!endprocedure


@enduml