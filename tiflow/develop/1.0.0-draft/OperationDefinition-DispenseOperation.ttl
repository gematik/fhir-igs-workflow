<https://gematik.de/fhir/tiflow/core/OperationDefinition/DispenseOperation> a fhir:OperationDefinition ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "DispenseOperation"] ; # 
  fhir:url [
     fhir:v "https://gematik.de/fhir/erp/OperationDefinition/DispenseOperationDefinition"^^xsd:anyURI ;
