       fhir:short [ fhir:v "boolean | code | Coding — Typ des value-Felds" ] ;
       fhir:definition [ fhir:v "boolean | code | Coding — Typ des value-Felds" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
