@prefix fhir: <http://hl7.org/fhir/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

<https://gematik.de/fhir/tiflow-erezept/OperationOutcome/ExampleRxDispenseOperationOutcomeError> a fhir:OperationOutcome ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:Resource.id [ fhir:value "ExampleRxDispenseOperationOutcomeError"] ;
  fhir:OperationOutcome.issue [
     fhir:index 0 ;
     fhir:OperationOutcome.issue.severity [ fhir:value "error" ] ;
     fhir:OperationOutcome.issue.code [ fhir:value "invalid" ] ;
     fhir:OperationOutcome.issue.details [
       fhir:CodeableConcept.coding [
         fhir:index 0 ;
         fhir:Coding.system [ fhir:value "https://gematik.de/fhir/tiflow/core/CodeSystem/tiflow-operation-outcome-details-cs" ] ;
         fhir:Coding.code [ fhir:value "TIFLOW_TASK_STATUS_MISMATCH" ] ;
         fhir:Coding.display [ fhir:value "Task status mismatch" ]
       ] ;
       fhir:CodeableConcept.text [ fhir:value "Task has invalid status." ]
     ]
  ] .

# - ontology header ------------------------------------------------------------

<https://gematik.de/fhir/tiflow-erezept/OperationOutcome/ExampleRxDispenseOperationOutcomeError.ttl> a owl:Ontology ;
  owl:imports fhir:fhir.ttl .

