# - resource -------------------------------------------------------------------

<https://gematik.de/fhir/tiflow-erezept/OperationOutcome/ExampleRxRejectOperationOutcomeError> a fhir:OperationOutcome ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:Resource.id [ fhir:value "ExampleRxRejectOperationOutcomeError"] ;
  fhir:OperationOutcome.issue [
     fhir:index 0 ;
     fhir:OperationOutcome.issue.severity [ fhir:value "error" ] ;
     fhir:OperationOutcome.issue.code [ fhir:value "invalid" ] ;
     fhir:OperationOutcome.issue.details [
       fhir:CodeableConcept.coding [
         fhir:index 0 ;
         fhir:Coding.system [ fhir:value "https://gematik.de/fhir/tiflow/core/CodeSystem/tiflow-operation-outcome-details-cs" ] ;
         fhir:Coding.code [ fhir:value "TIFLOW_AUTH_ROLE_NOT_ALLOWED" ] ;
         fhir:Coding.display [ fhir:value "Access role not allowed" ]
       ] ;
       fhir:CodeableConcept.text [ fhir:value "Der Nutzer ist nicht berechtigt, die aufgerufene Operation anzufordern" ]
     ]
  ] .

# - ontology header ------------------------------------------------------------

<https://gematik.de/fhir/tiflow-erezept/OperationOutcome/ExampleRxRejectOperationOutcomeError.ttl> a owl:Ontology ;
