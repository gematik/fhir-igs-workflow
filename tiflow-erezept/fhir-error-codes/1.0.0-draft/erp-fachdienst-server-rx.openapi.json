          },
          {
            "$ref": "#/components/parameters/elements"
          },
          {
            "name": "authored-on",
            "in": "query",
            "description": "Search by creation date",
            "schema": {
              "type": "string",
              "pattern": "([0-9]([0-9]([0-9][1-9]|[1-9]0)|[1-9]00)|[1-9]000)(-(0[1-9]|1[0-2])(-(0[1-9]|[1-2][0-9]|3[0-1])(T([01][0-9]|2[0-3]):[0-5][0-9]:([0-5][0-9]|60)(\\.[0-9]+)?(Z|(\\+|-)((0[0-9]|1[0-3]):[0-5][0-9]|14:00)))?)?)?"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Search by task status",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "expiry-date",
            "in": "query",
            "description": "Task.extension:expiryDate.valueDate - Unterstützt die Suche nach dem Verfallsdatum",
            "schema": {
              "type": "string",
              "pattern": "([0-9]([0-9]([0-9][1-9]|[1-9]0)|[1-9]00)|[1-9]000)(-(0[1-9]|1[0-2])(-(0[1-9]|[1-2][0-9]|3[0-1])(T([01][0-9]|2[0-3]):[0-5][0-9]:([0-5][0-9]|60)(\\.[0-9]+)?(Z|(\\+|-)((0[0-9]|1[0-3]):[0-5][0-9]|14:00)))?)?)?"
            }
          },
          {
            "name": "accept-date",
            "in": "query",
            "description": "Task.extension:acceptDate.valueDate - Unterstützt die Suche nach dem Akzeptanzdatum",
            "schema": {
              "type": "string",
              "pattern": "([0-9]([0-9]([0-9][1-9]|[1-9]0)|[1-9]00)|[1-9]000)(-(0[1-9]|1[0-2])(-(0[1-9]|[1-2][0-9]|3[0-1])(T([01][0-9]|2[0-3]):[0-5][0-9]:([0-5][0-9]|60)(\\.[0-9]+)?(Z|(\\+|-)((0[0-9]|1[0-3]):[0-5][0-9]|14:00)))?)?)?"
            }
          },
          {
            "name": "modified",
            "in": "query",
            "description": "Search by last modification date",
            "schema": {
              "type": "string",
              "pattern": "([0-9]([0-9]([0-9][1-9]|[1-9]0)|[1-9]00)|[1-9]000)(-(0[1-9]|1[0-2])(-(0[1-9]|[1-2][0-9]|3[0-1])(T([01][0-9]|2[0-3]):[0-5][0-9]:([0-5][0-9]|60)(\\.[0-9]+)?(Z|(\\+|-)((0[0-9]|1[0-3]):[0-5][0-9]|14:00)))?)?)?"
            }
          },
          {
            "name": "_sort",
            "in": "query",
            "description": "Unterstützt das Sortieren nach unterstützten Task-Suchkriterien",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "_count",
            "in": "query",
            "description": "Maximale Anzahl zurückgegebener Einträge pro Seite; maximum value is 50",
            "schema": {
              "type": "number"
            }
          },
          {
            "name": "_offset",
            "in": "query",
            "description": "Nullbasierter Offset des ersten zurückgegebenen Eintrags; default is 0",
            "schema": {
              "type": "number"
            }
          }
        ]
      }
    },
