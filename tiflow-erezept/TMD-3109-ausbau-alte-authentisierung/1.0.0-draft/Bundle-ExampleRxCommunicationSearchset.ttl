     fhir:relation [ fhir:v "self" ] ;
     fhir:url [
       fhir:v "https://erp-ref.example.org/Communication?received=NULL"^^xsd:anyURI ;
       fhir:l <https://erp-ref.example.org/Communication?received=NULL>
     ]
  ] ) ; # 
  fhir:entry ( [
     fhir:fullUrl [
