     ] ;
     fhir:resource ( <https://erp-ref.example.org/Communication/ExampleRxCommunicationDispReq> ) ;
     fhir:search [
       fhir:mode [ fhir:v "match" ]
     ]
  ] ) . # 

<https://erp-ref.example.org/Communication/ExampleRxCommunicationDispReq> a fhir:Communication ;
  fhir:id [ fhir:v "ExampleRxCommunicationDispReq"] ; # 
  fhir:status [ fhir:v "unknown"] ; # 
