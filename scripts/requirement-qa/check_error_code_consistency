#!/usr/bin/env python3
"""Run error_code_consistency as a local module without PYTHONPATH setup."""

from pathlib import Path
import sys


def main() -> int:
    # Make scripts/requirement-qa importable so error_code_consistency resolves.
    sys.path.insert(0, str(Path(__file__).resolve().parent))

    from error_code_consistency.cli import main as module_main

    return module_main()


if __name__ == "__main__":
    raise SystemExit(main())