<https://gematik.de/fhir/tiflow/diga/CapabilityStatement/erp-fachdienst-server-diga> a fhir:CapabilityStatement ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "erp-fachdienst-server-diga"] ; # 
