# - resource -------------------------------------------------------------------

<https://gematik.de/fhir/tiflow/diga/Parameters/ExampleDiGAOperationRequestParameters> a fhir:Parameters ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "ExampleDiGAOperationRequestParameters"] ; # 
  fhir:parameter ( [
     fhir:name [ fhir:v "accessCode" ] ;
     fhir:value [
       a fhir:String ;
       fhir:v "AC-162-EXAMPLE-0001"
     ]
  ] [
     fhir:name [ fhir:v "secret" ] ;
     fhir:value [
       a fhir:String ;
       fhir:v "SECRET-DIGA-01"
     ]
  ] ) . # 

