@prefix fhir: <http://hl7.org/fhir/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

<https://gematik.de/fhir/tiflow-diga/OperationOutcome/ExampleOperationRejectError> a fhir:OperationOutcome ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:Resource.id [ fhir:value "ExampleOperationRejectError"] ;
  fhir:OperationOutcome.issue [
     fhir:index 0 ;
     fhir:OperationOutcome.issue.severity [ fhir:value "error" ] ;
     fhir:OperationOutcome.issue.code [ fhir:value "forbidden" ] ;
     fhir:OperationOutcome.issue.details [
       fhir:CodeableConcept.text [ fhir:value "Task not in status in progress, is: ready" ]
     ]
  ] .

# - ontology header ------------------------------------------------------------

<https://gematik.de/fhir/tiflow-diga/OperationOutcome/ExampleOperationRejectError.ttl> a owl:Ontology ;
  owl:imports fhir:fhir.ttl .

