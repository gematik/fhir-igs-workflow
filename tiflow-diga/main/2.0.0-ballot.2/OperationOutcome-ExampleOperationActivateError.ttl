@prefix fhir: <http://hl7.org/fhir/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

<https://gematik.de/fhir/tiflow-diga/OperationOutcome/ExampleOperationActivateError> a fhir:OperationOutcome ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:Resource.id [ fhir:value "ExampleOperationActivateError"] ;
  fhir:OperationOutcome.issue [
     fhir:index 0 ;
     fhir:OperationOutcome.issue.severity [ fhir:value "error" ] ;
     fhir:OperationOutcome.issue.code [ fhir:value "invalid" ] ;
     fhir:OperationOutcome.issue.details [
       fhir:CodeableConcept.text [ fhir:value "unknown or unexpected profile" ]
     ] ;
     fhir:OperationOutcome.issue.diagnostics [ fhir:value "Unable to determine profile type from name: https://fhir.kbv.de/StructureDefinition/KBV_PR_ERP_Bundle" ]
  ] .

# - ontology header ------------------------------------------------------------

<https://gematik.de/fhir/tiflow-diga/OperationOutcome/ExampleOperationActivateError.ttl> a owl:Ontology ;
  owl:imports fhir:fhir.ttl .

