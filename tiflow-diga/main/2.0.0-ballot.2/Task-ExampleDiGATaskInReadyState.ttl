@prefix fhir: <http://hl7.org/fhir/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

<https://gematik.de/fhir/tiflow-diga/Task/ExampleDiGATaskInReadyState> a fhir:Task ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:Resource.id [ fhir:value "ExampleDiGATaskInReadyState"] ;
  fhir:Task.status [ fhir:value "ready"] ;
  fhir:Task.intent [ fhir:value "order"] ;
  fhir:Task.authoredOn [ fhir:value "2026-03-20"^^xsd:date] .

# - ontology header ------------------------------------------------------------

<https://gematik.de/fhir/tiflow-diga/Task/ExampleDiGATaskInReadyState.ttl> a owl:Ontology ;
  owl:imports fhir:fhir.ttl .

